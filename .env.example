# Exemplo de variáveis de ambiente — NÃO COMITAR CREDENCIAIS REAIS

# --- BACKEND (gateway) ---
# MongoDB (usado pelo gateway)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change_me
MONGO_DB_NAME=largo
MONGO_PORT=27017
# Connection string de exemplo para uso dentro de containers
MONGO_URI=mongodb://admin:change_me@mongo:27017/largo?authSource=admin

# JWT (gateway auth)
JWT_SECRET=changeme

# --- AI WORKER (ai) ---
# Chaves e modelos usados pelo ai-worker (NÃO COMITAR CHAVES REAIS)
GEMINI_API_KEY=
GEMINI_MODEL_IMAGE=gemini-3.1-flash
GEMINI_MODEL_TEXT=gemini-3.1-flash-lite
GOOGLE_API_KEY=

# --- FRONTEND (variáveis expostas ao browser devem usar prefixo VITE_) ---
# URL base que o frontend usa para chamar o gateway
VITE_API_BASE_URL=http://localhost:3000
# Exemplos de variáveis do frontend
VITE_SENTRY_DSN=

# --- DOCKER / COMPOSE ---
COMPOSE_PROJECT_NAME=largo
