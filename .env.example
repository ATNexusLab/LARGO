# Exemplo de variáveis de ambiente — NÃO COMITAR CREDENCIAIS REAIS
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change_me
MONGO_DB_NAME=largo
MONGO_PORT=27017
# Connection string de exemplo para uso dentro de containers
MONGO_URI=mongodb://admin:change_me@mongo:27017/largo?authSource=admin

# Outras variáveis do sistema (placeholders)
JWT_SECRET=changeme
GEMINI_API_KEY=
GOOGLE_CLOUD_API_KEY=
